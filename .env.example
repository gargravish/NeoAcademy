# =============================================================================
# NeoAcademy Environment Variables
# Copy this file to .env.local and fill in the values you need.
# API keys can also be managed via the Admin Portal (preferred) — the DB
# takes priority over .env values once you've completed the setup wizard.
# =============================================================================

# --- Authentication & Database -----------------------------------------------

# Secret used by Better Auth to sign session tokens (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Base URL of your NeoAcademy instance
BETTER_AUTH_URL=http://localhost:3000

# Path to the SQLite database file (default: ./data/neoacademy.db)
# DATABASE_PATH=./data/neoacademy.db

# --- Gemini (Primary Generation) ---------------------------------------------
# Multiple keys for free-tier rotation — one per GCP project (comma-separated)
GEMINI_FREE_KEYS=AIzaSy...,AIzaSy...,AIzaSy...

# Optional paid Tier 1 key (capped at GEMINI_PAID_MONTHLY_CAP_GBP)
GEMINI_PAID_KEY=

# Monthly spend cap for the paid key in GBP (default: 5.00)
GEMINI_PAID_MONTHLY_CAP_GBP=5.00

# Gemini model names
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_QUALITY_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- SiliconFlow (Cheap overflow — GLM-5, MiniMax, Kimi) ----------------------
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# --- OpenAI (Optional ultra-cheap fallback — GPT-5-nano) ---------------------
# Note: NOT your ChatGPT Plus subscription — needs separate API billing
OPENAI_API_KEY_DIRECT=

# --- Ollama (Local runtime — Qwen 3.5) ----------------------------------------
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://192.168.70.10:11434/v1
OPENAI_MODELS=qwen3.5:latest

# Default model for runtime operations (local Ollama)
DEFAULT_MODEL=openai:qwen3.5:latest

# --- TTS: Kokoro (Local) ------------------------------------------------------
TTS_OPENAI_API_KEY=kokoro
TTS_OPENAI_BASE_URL=http://192.168.70.10:8880/v1
TTS_DEFAULT_VOICE=af_bella

# --- ASR: Whisper (Local) -----------------------------------------------------
ASR_OPENAI_API_KEY=whisper
ASR_OPENAI_BASE_URL=http://192.168.70.10:8881/v1

# --- Web Search (all optional, DuckDuckGo always enabled for free) ------------
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# --- Knowledge Base (RAG) ----------------------------------------------------
# Path to LanceDB vector store (default: ./data/lancedb)
# LANCEDB_PATH=./data/lancedb

# --- Other LLM Providers (legacy/optional) -----------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

# Legacy Google key (use GEMINI_FREE_KEYS above for NeoAcademy)
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODELS=

KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODELS=

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODELS=

GLM_API_KEY=
GLM_BASE_URL=
GLM_MODELS=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=
SILICONFLOW_MODELS=

DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODELS=

